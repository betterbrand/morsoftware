generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            Int      @id @default(autoincrement())
  developerId   String   @unique
  username          String?
  email         String?   @unique
  walletAddress String?
  githubId     String
  avatarImgUrl  String?
  createdAt     DateTime @default(now())
}
